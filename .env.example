# LaughLoop Configuration
# Copy to .env and fill in your values

# Prime Intellect API key (required for training + inference)
PRIME_API_KEY=your_prime_api_key_here

# Prime team ID (required for team accounts — find at Team Profile page)
PRIME_TEAM_ID=

# Model serving config
LAUGHLOOP_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
LAUGHLOOP_BASE_URL=https://api.pinference.ai/api/v1
LAUGHLOOP_API_KEY=${PRIME_API_KEY}

# After first training run, set this to the deployed adapter ID
LAUGHLOOP_ADAPTER_ID=

# Judge model for environment (optional, improves training signal)
OPENAI_API_KEY=your_openai_key_here

# Log file directory (defaults to app/backend/logs/ for local dev)
LAUGHLOOP_LOG_DIR=

# Training loop config
LAUGHLOOP_MIN_BATCH=20
LAUGHLOOP_SAMPLE_MULTIPLIER=5
LAUGHLOOP_DATA_DIR=./data/batches

# ---------------------------------------------------------------------------
# Deployment (Vercel + R2)
# ---------------------------------------------------------------------------

# Cloudflare R2 object store (optional — when set, logs are stored in R2
# instead of local files. Required for Vercel/serverless deployments.)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=laughloop
R2_LOG_KEY=logs/interactions.jsonl

# Frontend: set NEXT_PUBLIC_API_URL to the deployed backend URL
# (leave empty for local dev — Next.js rewrites proxy /api to localhost:8000)
NEXT_PUBLIC_API_URL=
